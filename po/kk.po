#: src/ptyxis-preferences-window.ui:720
msgid "New Window"
msgstr "Жаңа терезе"

#: data/org.gnome.Ptyxis.desktop.in.in:27 src/org.gnome.Ptyxis.gschema.xml.in:399
#: src/ptyxis-preferences-window.ui:746
msgid "New Tab"
msgstr "Жаңа бет"

#: data/org.gnome.Ptyxis.desktop.in.in:31 src/org.gnome.Ptyxis.gschema.xml.in:417
#: src/ptyxis-preferences-window.ui:921
msgid "Preferences"
msgstr "Баптаулар"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:7
msgid "Container-oriented terminal"
msgstr "Контейнерге бағытталған терминал"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:9
msgid "Ptyxis is a terminal for GNOME that focuses on ease-of-use in a world of containers."
msgstr "Ptyxis - бұл контейнерлер әлемінде қолданудың жеңілдігіне бағытталған GNOME-ға арналған терминал."

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:13
msgid "Features:"
msgstr "Мүмкіндіктері:"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:15
msgid ""
"Remembers current container when opening a new tab with support for podman, toolbox, distrobox, and more"
msgstr ""
"Podman, toolbox, distrobox және т.б. қолдауымен жаңа бетті ашқанда ағымдағы контейнерді есте сақтайды"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:16
msgid "Configurable keyboard shortcuts"
msgstr "Теңшелетін пернетақта жарлықтары"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:17
msgid "Modern interface which integrates the palette with the window styling"
msgstr "Палитраны терезе стилімен біріктіретін заманауи интерфейс"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:18
msgid "User-installable color palettes"
msgstr "Пайдаланушы орната алатын түс палитралары"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:19
msgid "Support for preferences profiles with container integration"
msgstr "Контейнерлермен интеграцияланған баптаулар профильдерін қолдау"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:20
msgid "Integrated color palettes with light and dark support"
msgstr "Ашық және күңгірт режимдерді қолдайтын кірістірілген түс палитралары"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:21
msgid "Tabbed interface with tab overviews"
msgstr "Беттерге шолу мүмкіндігі бар беттік интерфейс"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:22
msgid "Efficient foreground process tracking denoting sudo and SSH"
msgstr "Sudo және SSH белгілейтін алдыңғы қатардағы процестерді тиімді бақылау"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:23
msgid "Support for transparent terminal backgrounds"
msgstr "Терминалдың мөлдір фондарына қолдау көрсету"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:24
msgid "Separate process mode for terminal-based applications"
msgstr "Терминалға негізделген қолданбалар үшін бөлек процесс режимі"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:25
msgid "Support for pinned tabs and saved sessions"
msgstr "Бекітілген беттер мен сақталған сессияларды қолдау"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:26
msgid "Terminal tabs are run within separate cgroups"
msgstr "Терминал беттері бөлек cgroups ішінде орындалады"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:27
msgid "Terminal inspector to help when writing terminal-based applications"
msgstr "Терминалға негізделген қолданбаларды жазу кезінде көмектесетін терминал инспекторы"

#. developer_name tag deprecated with Appstream 1.0
#: data/org.gnome.Ptyxis.metainfo.xml.in.in:32
msgid "Christian Hergert"
msgstr "Christian Hergert"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:72
msgid "A column and row size indicator is displayed when resizing the window"
msgstr "Терезе өлшемін өзгерткен кезде баған мен жол өлшемінің индикаторы көрсетіледі"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:77
msgid "Containers are automatically discovered and displayed"
msgstr "Контейнерлер автоматты түрде анықталады және көрсетіледі"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:82
msgid "Many behaviors of the terminal may be tweaked to user preference"
msgstr "Терминалдың көптеген мінез-құлықтарын пайдаланушы қалауы бойынша баптауға болады"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:87
msgid "You may rename a tab by providing a prefix to the title"
msgstr "Тақырыпқа префикс қосу арқылы беттің атын өзгертуге болады"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:92
msgid "Palettes provide an integrated dark mode"
msgstr "Палитралар кірістірілген күңгірт режимді қамтамасыз етеді"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:97
msgid "You can see an overview of your tabs at any time"
msgstr "Кез келген уақытта беттерге шолуды көруге болады"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:102
msgid "Many shortcuts may be remapped to user preference"
msgstr "Көптеген жарлықтарды пайдаланушы қалауы бойынша қайта тағайындауға болады"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:107
msgid "Built-in color palettes provide both dark and light mode variants"
msgstr "Кірістірілген түс палитралары күңгірт және ашық режим нұсқаларын ұсынады"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:112
msgid "Profiles allow for overriding a number of features such as default container"
msgstr "Профильдер әдепкі контейнер сияқты бірқатар мүмкіндіктерді қайта анықтауға мүмкіндік береді"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:117
msgid "The terminal will remind you when you're root on the local system"
msgstr "Локалды жүйеде root болған кезде терминал сізге ескертеді"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:122
msgid "The terminal will remind you when you're on a remote system"
msgstr "Қашықтағы жүйеде болған кезде терминал сізге ескертеді"

#: src/main.c:142 src/main.c:149 src/main.c:161
msgid "Error"
msgstr "Қате"

#: src/main.c:155
#, c-format
msgid ""
"Error: %s already exists.\n"
"Please remove it first.\n"
msgstr ""
"Қате: %s бұрыннан бар.\n"
"Алдымен оны өшіріңіз.\n"

#: src/org.gnome.Ptyxis.gschema.xml.in:101
msgid "Default Profile UUID"
msgstr "Әдепкі профильдің UUID коды"

#: src/org.gnome.Ptyxis.gschema.xml.in:102
msgid "The UUID of the default profile"
msgstr "Әдепкі профильдің UUID коды"

#: src/org.gnome.Ptyxis.gschema.xml.in:107
msgid "UUIDs of all Profiles"
msgstr "Барлық профильдердің UUID кодтары"

#: src/org.gnome.Ptyxis.gschema.xml.in:108
msgid "A list of UUID for every profile"
msgstr "Әр профиль үшін UUID тізімі"

#: src/org.gnome.Ptyxis.gschema.xml.in:113 src/ptyxis-preferences-window.ui:308
msgid "New Tab Position"
msgstr "Жаңа беттің орны"

#: src/org.gnome.Ptyxis.gschema.xml.in:114
msgid "Where to place new tabs"
msgstr "Жаңа беттерді қайда орналастыру керек"

#: src/org.gnome.Ptyxis.gschema.xml.in:119 src/ptyxis-preferences-window.ui:400
msgid "Audible Bell"
msgstr "Дыбыстық сигнал"

#: src/org.gnome.Ptyxis.gschema.xml.in:120
msgid "If an audible bell should be used"
msgstr "Дыбыстық сигналды пайдалану керек пе"

#: src/org.gnome.Ptyxis.gschema.xml.in:125
msgid "Visible Bell"
msgstr "Визуалды сигнал"

#: src/org.gnome.Ptyxis.gschema.xml.in:126
msgid "If a visual bell should be used"
msgstr "Визуалды сигналды пайдалану керек пе"

#: src/org.gnome.Ptyxis.gschema.xml.in:131
msgid "Visual Process Leader"
msgstr "Визуалды процесс көшбасшысы"

#: src/org.gnome.Ptyxis.gschema.xml.in:132
msgid "Display a visual window highlight when process leader is SSH, sudo, or other specialized tooling"
msgstr ""
"Процесс көшбасшысы SSH, sudo немесе басқа арнайы құрал болған кезде терезенің визуалды ерекшеленуін "
"көрсету"

#: src/org.gnome.Ptyxis.gschema.xml.in:137
msgid "Use System Font"
msgstr "Жүйелік қаріпті пайдалану"

#: src/org.gnome.Ptyxis.gschema.xml.in:138
msgid "If the default system monospace font should be used"
msgstr "Әдепкі жүйелік моноеністі қаріпті пайдалану керек пе"

#: src/org.gnome.Ptyxis.gschema.xml.in:143
msgid "Font Name"
msgstr "Қаріп аты"

#: src/org.gnome.Ptyxis.gschema.xml.in:144
msgid "The font description to use if use-system-font is set to False"
msgstr "use-system-font параметрі False болса, қолданылатын қаріп сипаттамасы"

#: src/org.gnome.Ptyxis.gschema.xml.in:149 src/ptyxis-preferences-window.ui:235
msgid "Cursor Shape"
msgstr "Курсор пішіні"

#: src/org.gnome.Ptyxis.gschema.xml.in:150
msgid "The default shape of the cursor"
msgstr "Курсордың әдепкі пішіні"

#: src/org.gnome.Ptyxis.gschema.xml.in:155
msgid "Cursor Blink Mode"
msgstr "Курсордың жыпылықтау режимі"

#: src/org.gnome.Ptyxis.gschema.xml.in:156
msgid "The default blink mode cursor"
msgstr "Курсордың әдепкі жыпылықтау режимі"

#: src/org.gnome.Ptyxis.gschema.xml.in:161
msgid "List of punctuation characters that are treated as word characters"
msgstr "Сөз таңбалары ретінде қарастырылатын тыныс белгілерінің тізімі"

#: src/org.gnome.Ptyxis.gschema.xml.in:162
msgid ""
"By default, when doing word-wise selection, most punctuation breaks up word boundaries. This list of "
"exceptions will instead be treated as part of the word."
msgstr ""
"Әдепкі бойынша, сөз бойынша таңдау кезінде тыныс белгілерінің көбі сөз шекараларын бөледі. Бұл "
"ерекшеліктер тізімі оның орнына сөздің бөлігі ретінде қарастырылады."

#: src/org.gnome.Ptyxis.gschema.xml.in:167
msgid "Scrollbar Policy"
msgstr "Айналдыру жолағының саясаты"

#: src/org.gnome.Ptyxis.gschema.xml.in:168
msgid "If scrollbars should be displayed"
msgstr "Айналдыру жолақтарын көрсету керек пе"

#: src/org.gnome.Ptyxis.gschema.xml.in:177
msgid "Text Blink Mode"
msgstr "Мәтіннің жыпылықтау режимі"

#: src/org.gnome.Ptyxis.gschema.xml.in:178
msgid "When text blinking is allowed"
msgstr "Мәтін жыпылықтауына қашан рұқсат етіледі"

#: src/org.gnome.Ptyxis.gschema.xml.in:183
msgid "Interface Style"
msgstr "Интерфейс стилі"

#: src/org.gnome.Ptyxis.gschema.xml.in:184
msgid "If light or dark interface style should be used"
msgstr "Ашық немесе күңгірт интерфейс стилін пайдалану керек пе"

#: src/org.gnome.Ptyxis.gschema.xml.in:189 src/ptyxis-preferences-window.ui:337
msgid "Restore Session"
msgstr "Сессияны қалпына келтіру"

#: src/org.gnome.Ptyxis.gschema.xml.in:190
msgid "Restore tabs from previous session when starting Ptyxis"
msgstr "Ptyxis іске қосылғанда алдыңғы сессиядағы беттерді қалпына келтіру"

#: src/org.gnome.Ptyxis.gschema.xml.in:195 src/ptyxis-preferences-window.ui:343
msgid "Restore Window Size"
msgstr "Терезе өлшемін қалпына келтіру"

#: src/org.gnome.Ptyxis.gschema.xml.in:196
msgid "Restore the previous window size when creating new windows"
msgstr "Жаңа терезелерді жасағанда алдыңғы терезе өлшемін қалпына келтіру"

#: src/org.gnome.Ptyxis.gschema.xml.in:206
msgid "Default Column Size"
msgstr "Бағандардың әдепкі өлшемі"

#: src/org.gnome.Ptyxis.gschema.xml.in:207 src/org.gnome.Ptyxis.gschema.xml.in:214
msgid "Default window size when restore-window-size is not true."
msgstr "restore-window-size параметрі ақиқат болмағандағы әдепкі терезе өлшемі."

#: src/org.gnome.Ptyxis.gschema.xml.in:213
msgid "Default Row Size"
msgstr "Жолдардың әдепкі өлшемі"

#: src/org.gnome.Ptyxis.gschema.xml.in:219
msgid "Toast on Copy Clipboard"
msgstr "Алмасу буферіне көшіру кезіндегі хабарлама"

#: src/org.gnome.Ptyxis.gschema.xml.in:220
msgid "Show the user when text has copied to the clipboard."
msgstr "Мәтін алмасу буферіне көшірілгенде пайдаланушыға көрсету."

#: src/org.gnome.Ptyxis.gschema.xml.in:225
msgid "Enable Accessibility"
msgstr "Қолжетімділікті іске қосу"

#: src/org.gnome.Ptyxis.gschema.xml.in:226
msgid "Currently experimental feature to send accessibility information to screen readers."
msgstr ""
"Экраннан оқу бағдарламаларына қолжетімділік туралы ақпаратты жіберуге арналған эксперименттік функция."

#: src/org.gnome.Ptyxis.gschema.xml.in:231
msgid "Disable Padding around Terminal Emulator"
msgstr "Терминал эмуляторының айналасындағы шегіністерді сөндіру"

#: src/org.gnome.Ptyxis.gschema.xml.in:232
msgid ""
"Do not pad around the terminal emulator widget. Setting to true may have significant performance impacts."
msgstr ""
"Терминал эмуляторының виджеті айналасында шегіністер жасамау. Ақиқат мәніне орнату өнімділікке "
"айтарлықтай әсер етуі мүмкін."

#: src/org.gnome.Ptyxis.gschema.xml.in:237
msgid "Prompt when active tab is closed"
msgstr "Белсенді бет жабылғанда сұрау"

#: src/org.gnome.Ptyxis.gschema.xml.in:238
msgid "If a tab (or window) is closed with active foreground processes, prompt the user for confirmation."
msgstr ""
"Егер бет (немесе терезе) белсенді алдыңғы қатардағы процестермен жабылса, пайдаланушыдан растауды сұрау."

#. Translators: OSC stands for "Operating System Command" and is referencing
#. in-band escape sequences from the child process to set the title
#: src/org.gnome.Ptyxis.gschema.xml.in:244
msgid "Ignore OSC Title"
msgstr "OSC тақырыбын елемеу"

#: src/org.gnome.Ptyxis.gschema.xml.in:245
msgid "If OSC title should be ignored in tab titles."
msgstr "Бет тақырыптарында OSC тақырыбын елемеу керек пе."

#: src/org.gnome.Ptyxis.gschema.xml.in:254
msgid "Label"
msgstr "Белгі"

#: src/org.gnome.Ptyxis.gschema.xml.in:255
msgid "The label for the profile"
msgstr "Профильге арналған белгі"

#: src/org.gnome.Ptyxis.gschema.xml.in:260
msgid "Login Shell"
msgstr "Кіру қоршамы"

#: src/org.gnome.Ptyxis.gschema.xml.in:261
msgid "Use a login shell"
msgstr "Кіру қоршамын пайдалану"

#: src/org.gnome.Ptyxis.gschema.xml.in:266 src/ptyxis-preferences-window.ui:468
#: src/ptyxis-profile-editor.ui:319
msgid "Limit Scrollback"
msgstr "Айналдыру тарихын шектеу"

#: src/org.gnome.Ptyxis.gschema.xml.in:267
msgid "Limit the number of lines to keep for scrollback"
msgstr "Айналдыру тарихы үшін сақталатын жолдар санын шектеу"

#: src/org.gnome.Ptyxis.gschema.xml.in:273 src/ptyxis-preferences-window.ui:477
#: src/ptyxis-profile-editor.ui:328
msgid "Scrollback Lines"
msgstr "Айналдыру тарихының жолдары"

#: src/org.gnome.Ptyxis.gschema.xml.in:274
msgid "The number of lines to keep in the scrollback, zero for no scrollback"
msgstr "Айналдыру тарихында сақталатын жолдар саны, нөл - айналдыру тарихы жоқ"

#: src/org.gnome.Ptyxis.gschema.xml.in:279 src/ptyxis-preferences-window.ui:458
#: src/ptyxis-profile-editor.ui:309
msgid "Scroll on Output"
msgstr "Шығыс кезінде айналдыру"

#: src/org.gnome.Ptyxis.gschema.xml.in:280
msgid "Scroll to the bottom upon new output"
msgstr "Жаңа шығыс пайда болғанда төменге айналдыру"

#: src/org.gnome.Ptyxis.gschema.xml.in:285 src/ptyxis-preferences-window.ui:452
#: src/ptyxis-profile-editor.ui:303
msgid "Scroll on Keystroke"
msgstr "Пернені басқанда айналдыру"

#: src/org.gnome.Ptyxis.gschema.xml.in:286
msgid "Scroll to the bottom upon user keystroke"
msgstr "Пайдаланушы пернені басқанда төменге айналдыру"

#: src/org.gnome.Ptyxis.gschema.xml.in:291 src/ptyxis-profile-editor.ui:173
msgid "Use Custom Command"
msgstr "Реттелетін команданы пайдалану"

#: src/org.gnome.Ptyxis.gschema.xml.in:292
msgid "If a custom command should be used"
msgstr "Реттелетін команданы пайдалану керек пе"

#: src/org.gnome.Ptyxis.gschema.xml.in:297
msgid "Use Proxy"
msgstr "Проксиді пайдалану"

#: src/org.gnome.Ptyxis.gschema.xml.in:298
msgid "Apply proxy settings from the host in the container"
msgstr "Хосттың прокси параметрлерін контейнерде іске асыру"

#: src/org.gnome.Ptyxis.gschema.xml.in:303 src/ptyxis-profile-editor.ui:178
msgid "Custom Command"
msgstr "Реттелетін команда"

