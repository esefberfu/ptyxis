#: data/org.gnome.Ptyxis.desktop.in.in:2 data/org.gnome.Ptyxis.metainfo.xml.in.in:6
msgid "@APP_NAME@"
msgstr "@APP_NAME@"

#: data/org.gnome.Ptyxis.desktop.in.in:3
msgid "A container-oriented terminal for GNOME"
msgstr "コンテナ志向の GNOME 向けターミナル"

#: data/org.gnome.Ptyxis.desktop.in.in:12 src/ptyxis-preferences-window.ui:655 src/ptyxis-tab.c:1465
#: src/ptyxis-util.c:318
msgid "Terminal"
msgstr "ターミナル"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
