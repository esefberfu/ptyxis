#: data/org.gnome.Ptyxis.desktop.in.in:2 data/org.gnome.Ptyxis.metainfo.xml.in.in:6
msgid "@APP_NAME@"
msgstr ""

#: data/org.gnome.Ptyxis.desktop.in.in:3
msgid "A container-oriented terminal for GNOME"
msgstr "Kontejnerově orientovaný terminál pro GNOME"

#: data/org.gnome.Ptyxis.desktop.in.in:12 src/ptyxis-preferences-window.ui:655 src/ptyxis-tab.c:1465
#: src/ptyxis-util.c:318
msgid "Terminal"
msgstr "Terminál"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Ptyxis.desktop.in.in:14
msgid "terminal;prompt;ptyxis;shell;command;commandline;cmd;cli;console;container;podman;toolbox;distrobox;"
msgstr "terminál;prompt;ptyxis;shell;příkaz;příkazový;řádek;cmd;cli;konzole;kontejner;podman;toolbox;distrobox;"

#: data/org.gnome.Ptyxis.desktop.in.in:23 src/org.gnome.Ptyxis.gschema.xml.in:405
#: src/ptyxis-preferences-window.ui:720
msgid "New Window"
msgstr "Nové okno"

#: data/org.gnome.Ptyxis.desktop.in.in:27 src/org.gnome.Ptyxis.gschema.xml.in:399
#: src/ptyxis-preferences-window.ui:746
msgid "New Tab"
msgstr "Nová karta"

#: data/org.gnome.Ptyxis.desktop.in.in:31 src/org.gnome.Ptyxis.gschema.xml.in:417
#: src/ptyxis-preferences-window.ui:921
msgid "Preferences"
msgstr "Předvolby"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:7
msgid "Container-oriented terminal"
msgstr "Kontejnerově orientovaný terminál"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:9
msgid "Ptyxis is a terminal for GNOME that focuses on ease-of-use in a world of containers."
msgstr "Ptyxis je terminál pro prostředí GNOME, který se zaměřuje na snadné použití ve světě kontejnerů."

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:13
msgid "Features:"
msgstr "Funkce:"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:15
msgid "Remembers current container when opening a new tab with support for podman, toolbox, distrobox, and more"
msgstr ""
"Pamatuje si aktuální kontejner při otevření nové karty s podporou pro podman, toolbox, distrobox a další"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:16
msgid "Configurable keyboard shortcuts"
msgstr "Nastavitelné klávesové zkratky"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:17
msgid "Modern interface which integrates the palette with the window styling"
msgstr "Moderní rozhraní, které integruje paletu se stylem okna"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:18
msgid "User-installable color palettes"
msgstr "Uživatelem instalovatelné barevné palety"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:19
msgid "Support for preferences profiles with container integration"
msgstr "Podpora profilů předvoleb s integrací kontejnerů"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:20
msgid "Integrated color palettes with light and dark support"
msgstr "Integrované barevné palety s podporou světlých a tmavých"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:21
msgid "Tabbed interface with tab overviews"
msgstr "Rozhraní s kartami a přehledy karet"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:22
msgid "Efficient foreground process tracking denoting sudo and SSH"
msgstr "Efektivní sledování procesů na popředí označující sudo a SSH"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:23
msgid "Support for transparent terminal backgrounds"
msgstr "Podpora průhledných pozadí terminálu"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:24
msgid "Separate process mode for terminal-based applications"
msgstr "Samostatný procesní režim pro aplikace založené na terminálu"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:25
msgid "Support for pinned tabs and saved sessions"
msgstr "Podpora pro připnuté karty a uložená sezení"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:26
msgid "Terminal tabs are run within separate cgroups"
msgstr "Karty terminálu se spouštějí v samostatných cgroups"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:27
msgid "Terminal inspector to help when writing terminal-based applications"
msgstr "Terminálový inspektor pro pomoc při psaní aplikací založených na terminálu"

#. developer_name tag deprecated with Appstream 1.0
#: data/org.gnome.Ptyxis.metainfo.xml.in.in:32
msgid "Christian Hergert"
msgstr "Christian Hergert"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:52
msgid "A column and row size indicator is displayed when resizing the window"
msgstr "Při změně velikosti okna se zobrazí indikátor velikosti sloupce a řádku"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:57
msgid "Containers are automatically discovered and displayed"
msgstr "Kontejnery jsou automaticky objeveny a zobrazeny"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:62
msgid "Many behaviors of the terminal may be tweaked to user preference"
msgstr "Mnoho chování terminálu lze upravit podle preferencí uživatele"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:67
msgid "You may rename a tab by providing a prefix to the title"
msgstr "Kartu můžete přejmenovat zadáním předpony názvu"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:72
msgid "Palettes provide an integrated dark mode"
msgstr "Palety poskytují integrovaný tmavý režim"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:77
msgid "You can see an overview of your tabs at any time"
msgstr "Přehled svých karet můžete kdykoli zobrazit"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:82
msgid "Many shortcuts may be remapped to user preference"
msgstr "Mnoho zkratek může být přemapováno podle preferencí uživatele"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:87
msgid "Built-in color palettes provide both dark and light mode variants"
msgstr "Vestavěné barevné palety poskytují varianty tmavého i světlého režimu"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:92
msgid "Profiles allow for overriding a number of features such as default container"
msgstr "Profily umožňují přepsat řadu funkcí, jako je výchozí kontejner"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:97
msgid "The terminal will remind you when you're root on the local system"
msgstr "Terminál vás upozorní, pokud jste root v místním systému"

#: data/org.gnome.Ptyxis.metainfo.xml.in.in:102
msgid "The terminal will remind you when you're on a remote system"
msgstr "Terminál vás upozorní, pokud jste na vzdáleném systému"

#: src/main.c:142 src/main.c:149 src/main.c:161
msgid "Error"
msgstr "Chyba"

#: src/main.c:155
#, c-format
msgid ""
"Error: %s already exists.\n"
"Please remove it first.\n"
msgstr ""
"Chyba: %s již existuje.\n"
"Nejprve jej prosím odstraňte.\n"

#: src/org.gnome.Ptyxis.gschema.xml.in:101
msgid "Default Profile UUID"
msgstr "UUID výchozího profilu"

#: src/org.gnome.Ptyxis.gschema.xml.in:102
msgid "The UUID of the default profile"
msgstr "UUID výchozího profilu"

#: src/org.gnome.Ptyxis.gschema.xml.in:107
msgid "UUIDs of all Profiles"
msgstr "UUID všech profilů"

#: src/org.gnome.Ptyxis.gschema.xml.in:108
msgid "A list of UUID for every profile"
msgstr "Seznam UUID pro každý profil"

#: src/org.gnome.Ptyxis.gschema.xml.in:113 src/ptyxis-preferences-window.ui:308
msgid "New Tab Position"
msgstr "Umístění nové karty"

#: src/org.gnome.Ptyxis.gschema.xml.in:114
msgid "Where to place new tabs"
msgstr "Kam umístit nové karty"

#: src/org.gnome.Ptyxis.gschema.xml.in:119 src/ptyxis-preferences-window.ui:400
msgid "Audible Bell"
msgstr "Slyšitelný zvonek"

#: src/org.gnome.Ptyxis.gschema.xml.in:120
msgid "If an audible bell should be used"
msgstr "Zda by měl být použit slyšitelný zvonek"

#: src/org.gnome.Ptyxis.gschema.xml.in:125
msgid "Visible Bell"
msgstr "Viditelný zvonek"

#: src/org.gnome.Ptyxis.gschema.xml.in:126
msgid "If a visual bell should be used"
msgstr "Zda by měl být použit viditelný zvonek"

#: src/org.gnome.Ptyxis.gschema.xml.in:131
msgid "Visual Process Leader"
msgstr "Viditelný vedoucí proces"

#: src/org.gnome.Ptyxis.gschema.xml.in:132
msgid "Display a visual window highlight when process leader is SSH, sudo, or other specialized tooling"
msgstr ""
"Zobrazit viditelné zvýraznění okna, když je vedoucím procesem SSH, sudo nebo jiný specializovaný nástroj"

#: src/org.gnome.Ptyxis.gschema.xml.in:137
msgid "Use System Font"
msgstr "Použít systémové písmo"

#: src/org.gnome.Ptyxis.gschema.xml.in:138
msgid "If the default system monospace font should be used"
msgstr "Zda by se mělo používat systémové písmo s pevnou šířkou"

#: src/org.gnome.Ptyxis.gschema.xml.in:143
msgid "Font Name"
msgstr "Název písma"

#: src/org.gnome.Ptyxis.gschema.xml.in:144
msgid "The font description to use if use-system-font is set to False"
msgstr "Popis písma, který se má použít, pokud je use-system-font nastaveno na False"

#: src/org.gnome.Ptyxis.gschema.xml.in:149 src/ptyxis-preferences-window.ui:235
msgid "Cursor Shape"
msgstr "Tvar kurzoru"

#: src/org.gnome.Ptyxis.gschema.xml.in:150
msgid "The default shape of the cursor"
msgstr "Výchozí tvar kurzoru"

#: src/org.gnome.Ptyxis.gschema.xml.in:155
msgid "Cursor Blink Mode"
msgstr "Režim blikání kurzoru"

#: src/org.gnome.Ptyxis.gschema.xml.in:156
msgid "The default blink mode cursor"
msgstr "Výchozí režim blikání kurzoru"

#: src/org.gnome.Ptyxis.gschema.xml.in:161
msgid "List of punctuation characters that are treated as word characters"
msgstr "Seznam interpunkčních znaků, které jsou považovány za znaky slova"

#: src/org.gnome.Ptyxis.gschema.xml.in:162
msgid ""
"By default, when doing word-wise selection, most punctuation breaks up word boundaries. This list of "
"exceptions will instead be treated as part of the word."
msgstr ""
"Ve výchozím nastavení, když provádíte výběr po slovech, většina interpunkce rozděluje hranice slov. Tento "
"seznam výjimek bude místo toho považován za součást slova."

#: src/org.gnome.Ptyxis.gschema.xml.in:167
msgid "Scrollbar Policy"
msgstr "Zásady posuvníku"

#: src/org.gnome.Ptyxis.gschema.xml.in:168
msgid "If scrollbars should be displayed"
msgstr "Zda mají být zobrazeny posuvníky"

#: src/org.gnome.Ptyxis.gschema.xml.in:177
msgid "Text Blink Mode"
msgstr "Režim blikání textu"

#: src/org.gnome.Ptyxis.gschema.xml.in:178
msgid "When text blinking is allowed"
msgstr "Kdy je povoleno blikání textu"

#: src/org.gnome.Ptyxis.gschema.xml.in:183
msgid "Interface Style"
msgstr "Styl rozhraní"

#: src/org.gnome.Ptyxis.gschema.xml.in:184
msgid "If light or dark interface style should be used"
msgstr "Zda by měl být použit světlý nebo tmavý styl rozhraní"

#: src/org.gnome.Ptyxis.gschema.xml.in:189 src/ptyxis-preferences-window.ui:337
msgid "Restore Session"
msgstr "Obnovit sezení"

#: src/org.gnome.Ptyxis.gschema.xml.in:190
msgid "Restore tabs from previous session when starting Ptyxis"
msgstr "Obnovit karty z předchozího sezení při spuštění Ptyxis"

#: src/org.gnome.Ptyxis.gschema.xml.in:195 src/ptyxis-preferences-window.ui:343
msgid "Restore Window Size"
msgstr "Obnovit velikost okna"

#: src/org.gnome.Ptyxis.gschema.xml.in:196
msgid "Restore the previous window size when creating new windows"
msgstr "Obnovit předchozí velikost okna při vytváření nových oken"

#: src/org.gnome.Ptyxis.gschema.xml.in:206
msgid "Default Column Size"
msgstr "Výchozí velikost sloupce"

#: src/org.gnome.Ptyxis.gschema.xml.in:207 src/org.gnome.Ptyxis.gschema.xml.in:214
msgid "Default window size when restore-window-size is not true."
msgstr "Výchozí velikost okna, když hodnota restore-window-size není nastavena na hodnotu true."

#: src/org.gnome.Ptyxis.gschema.xml.in:213
msgid "Default Row Size"
msgstr "Výchozí velikost řádku"

#: src/org.gnome.Ptyxis.gschema.xml.in:219
msgid "Toast on Copy Clipboard"
msgstr "Upozornění při kopírování do schránky"

#: src/org.gnome.Ptyxis.gschema.xml.in:220
msgid "Show the user when text has copied to the clipboard."
msgstr "Zobrazit uživateli, když je text zkopírován do schránky."

#: src/org.gnome.Ptyxis.gschema.xml.in:225
msgid "Enable Accessibility"
msgstr "Povolit přístupnost"

#: src/org.gnome.Ptyxis.gschema.xml.in:226
msgid "Currently experimental feature to send accessibility information to screen readers."
msgstr "V současné době experimentální funkce pro odesílání informací usnadnění do čteček obrazovky."

#: src/org.gnome.Ptyxis.gschema.xml.in:231
msgid "Disable Padding around Terminal Emulator"
msgstr "Zakázat odsazení kolem emulátoru terminálu"

#: src/org.gnome.Ptyxis.gschema.xml.in:232
msgid ""
"Do not pad around the terminal emulator widget. Setting to true may have significant performance impacts."
msgstr "Nezakrývat widget emulátoru terminálu. Nastavení na hodnotu true může mít významný dopad na výkon."

#: src/org.gnome.Ptyxis.gschema.xml.in:237
msgid "Prompt when active tab is closed"
msgstr "Dotázat se při zavření aktivní karty"

#: src/org.gnome.Ptyxis.gschema.xml.in:238
msgid "If a tab (or window) is closed with active foreground processes, prompt the user for confirmation."
msgstr "Pokud je karta (nebo okno) zavřena s aktivními procesy v popředí, požádat uživatele o potvrzení."

#. Translators: OSC stands for "Operating System Command" and is referencing in-band escape sequences from the child process to set the title
#: src/org.gnome.Ptyxis.gschema.xml.in:244
msgid "Ignore OSC Title"
msgstr "Ignorovat název OSC"

#: src/org.gnome.Ptyxis.gschema.xml.in:245
msgid "If OSC title should be ignored in tab titles."
msgstr "Zda by měl být název OSC ignorován v názvech karet."

#: src/org.gnome.Ptyxis.gschema.xml.in:254
msgid "Label"
msgstr "Označení"

#: src/org.gnome.Ptyxis.gschema.xml.in:255
msgid "The label for the profile"
msgstr "Označení profilu"

#: src/org.gnome.Ptyxis.gschema.xml.in:260
msgid "Login Shell"
msgstr "Přihlašovací shell"

#: src/org.gnome.Ptyxis.gschema.xml.in:261
msgid "Use a login shell"
msgstr "Použít přihlašovací shell"

#: src/org.gnome.Ptyxis.gschema.xml.in:266 src/ptyxis-preferences-window.ui:468 src/ptyxis-profile-editor.ui:319
msgid "Limit Scrollback"
msgstr "Omezení posunu zpět"

#: src/org.gnome.Ptyxis.gschema.xml.in:267
msgid "Limit the number of lines to keep for scrollback"
msgstr "Omezit počet řádků, které se mají ponechat pro posun zpět"

#: src/org.gnome.Ptyxis.gschema.xml.in:273 src/ptyxis-preferences-window.ui:477 src/ptyxis-profile-editor.ui:328
msgid "Scrollback Lines"
msgstr "Řádky pro posun zpět"

#: src/org.gnome.Ptyxis.gschema.xml.in:274
msgid "The number of lines to keep in the scrollback, zero for no scrollback"
msgstr "Počet řádků, které se mají ponechat ve zpětném posunu, nula pro zákaz posunu zpět"

#: src/org.gnome.Ptyxis.gschema.xml.in:279 src/ptyxis-preferences-window.ui:458 src/ptyxis-profile-editor.ui:309
msgid "Scroll on Output"
msgstr "Posunout při výstupu"

#: src/org.gnome.Ptyxis.gschema.xml.in:280
msgid "Scroll to the bottom upon new output"
msgstr "Posunout dolů při novém výstupu"

#: src/org.gnome.Ptyxis.gschema.xml.in:285 src/ptyxis-preferences-window.ui:452 src/ptyxis-profile-editor.ui:303
msgid "Scroll on Keystroke"
msgstr "Posunout při zmáčknutí klávesy"

#: src/org.gnome.Ptyxis.gschema.xml.in:286
msgid "Scroll to the bottom upon user keystroke"
msgstr "Posunout dolů při stisku klávesy uživatelem"

#: src/org.gnome.Ptyxis.gschema.xml.in:291 src/ptyxis-profile-editor.ui:173
msgid "Use Custom Command"
msgstr "Použít vlastní příkaz"

#: src/org.gnome.Ptyxis.gschema.xml.in:292
msgid "If a custom command should be used"
msgstr "Zda by měl být použit vlastní příkaz"

#: src/org.gnome.Ptyxis.gschema.xml.in:297
msgid "Use Proxy"
msgstr "Použít proxy"

#: src/org.gnome.Ptyxis.gschema.xml.in:298
msgid "Apply proxy settings from the host in the container"
msgstr "Použít nastavení proxy z hostitele v kontejneru"

#: src/org.gnome.Ptyxis.gschema.xml.in:303 src/ptyxis-profile-editor.ui:178
msgid "Custom Command"
msgstr "Vlastní příkaz"

#: src/org.gnome.Ptyxis.gschema.xml.in:304
msgid "A custom command for the shell"
msgstr "Vlastní příkaz shellu"

#: src/org.gnome.Ptyxis.gschema.xml.in:309 src/ptyxis-profile-editor.ui:197
msgid "Default Container"
msgstr "Výchozí kontejner"

#: src/org.gnome.Ptyxis.gschema.xml.in:310
msgid "The default container to run the command in"
msgstr "Výchozí kontejner pro spuštění příkazu"

#: src/org.gnome.Ptyxis.gschema.xml.in:315 src/ptyxis-profile-editor.ui:206
msgid "Preserve Container"
msgstr "Zachovat kontejner"

#: src/org.gnome.Ptyxis.gschema.xml.in:316
msgid "Preserve the active container when creating new tabs and windows"
msgstr "Zachovat aktivní kontejner při vytváření nových karet a oken"

#: src/org.gnome.Ptyxis.gschema.xml.in:321 src/ptyxis-preferences-window.ui:537 src/ptyxis-profile-editor.ui:267
msgid "Exit Action"
msgstr "Akce při ukončení"

#: src/org.gnome.Ptyxis.gschema.xml.in:322
msgid "The action to take when the shell exits"
msgstr "Akce, která se má provést při ukončení shellu"

#: src/org.gnome.Ptyxis.gschema.xml.in:327
msgid "Preserve Directory"
msgstr "Zachovat složku"

#: src/org.gnome.Ptyxis.gschema.xml.in:328
msgid "If the directory should be preserved for new terminals"
msgstr "Zda by měla být složka zachována pro nové terminály"

#: src/org.gnome.Ptyxis.gschema.xml.in:333 src/ptyxis-inspector.ui:102 src/ptyxis-preferences-window.ui:40
#: src/ptyxis-profile-editor.ui:65
msgid "Palette"
msgstr "Paleta"

#: src/org.gnome.Ptyxis.gschema.xml.in:334
msgid "The color palette to use for the profile, by name"
msgstr "Paleta barev, která se má pro profil použít, podle názvu"

#: src/org.gnome.Ptyxis.gschema.xml.in:340
msgid "Opacity"
msgstr "Krytí"

#: src/org.gnome.Ptyxis.gschema.xml.in:341
msgid "The opacity of the palette background"
msgstr "Neprůhlednost pozadí palety"

#: src/org.gnome.Ptyxis.gschema.xml.in:346
msgid "Bold is Bright"
msgstr "Tučné je světlé"

#: src/org.gnome.Ptyxis.gschema.xml.in:347
msgid "Setting bold on one of the lower 8 colors in the palette will use bright variant (upper 8 colors)"
msgstr "Nastavení tučného písma na jednu z 8 spodních barev v paletě použije jasnou variantu (horních 8 barev)"

#: src/org.gnome.Ptyxis.gschema.xml.in:353 src/ptyxis-preferences-window.ui:175 src/ptyxis-profile-editor.ui:143
msgid "Line Spacing"
msgstr "Rozestup řádků"

#: src/org.gnome.Ptyxis.gschema.xml.in:354
msgid "The terminal’s cell height scale"
msgstr "Měřítko výšky buňky terminálu"

#: src/org.gnome.Ptyxis.gschema.xml.in:359
msgid "CJK Ambiguous Width"
msgstr "Nejednoznačná šířka CJK"

#: src/org.gnome.Ptyxis.gschema.xml.in:360
msgid "The size to apply to ambiguous width characters"
msgstr "Velikost, která se použije na znaky s nejednoznačnou šířkou"

#: src/org.gnome.Ptyxis.gschema.xml.in:365 src/org.gnome.Ptyxis.gschema.xml.in:371
msgid "Backspace Binding"
msgstr "Přiřazení backspace"

#: src/org.gnome.Ptyxis.gschema.xml.in:366 src/org.gnome.Ptyxis.gschema.xml.in:372
msgid "What to send to the PTY when a backspace is entered"
msgstr "Co poslat do PTY, když je zadán backspace"

#: src/org.gnome.Ptyxis.gschema.xml.in:377 src/ptyxis-preferences-window.ui:620 src/ptyxis-profile-editor.ui:395
msgid "Custom Links"
msgstr "Vlastní odkazy"

#: src/org.gnome.Ptyxis.gschema.xml.in:378
msgid ""
"A list of custom hyperlinks, each defined by a regular expression matching the text, and a replacement pattern"
msgstr ""
"Seznam vlastních hypertextových odkazů, každý definovaný regulárním výrazem odpovídajícím textu a náhradním "
"vzorem"

#: src/org.gnome.Ptyxis.gschema.xml.in:387 src/ptyxis-preferences-window.ui:658
msgid "Copy to Clipboard"
